# Docker Compose environment for Airlink v3.0 (copy to .env)
# These feed docker-compose.yml. Backend app config lives in backend/.env.

# --- MariaDB ---
DB_ROOT_PASSWORD=root_secret
DB_DATABASE=airlink
DB_USERNAME=airlink
DB_PASSWORD=airlink_pass
DB_PORT=3306

# --- Backend (Laravel API) ---
BACKEND_PORT=8000

# --- phpMyAdmin ---
PMA_PORT=8080

# --- Frontend (Vite) ---
FRONTEND_PORT=5173
